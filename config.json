{
  "project": "TCC-iNEST Research Platform",
  "version": "1.0.0",
  "description": "综合技术研究、专利撰写、论文撰写和工程代码开发平台",
  "two_directions": {
    "TCC": {
      "name": "TCC - Trusted Computing Cloud",
      "tags": [
        "trust",
        "security",
        "cloud",
        "verifiable"
      ],
      "focus_areas": [
        "Trusted Execution Environments",
        "Remote Attestation",
        "Cloud Security",
        "Hardware-rooted Trust",
        "Secure Multi-party Computation"
      ]
    },
    "iNEST": {
      "name": "iNEST - Intelligent Network Systems for Edge and Edge Computing",
      "tags": [
        "edge",
        "networking",
        "intelligent",
        "distributed"
      ],
      "focus_areas": [
        "Edge Computing",
        "Network Intelligence",
        "Distributed AI",
        "Topology Optimization",
        "Flexible Computing"
      ]
    }
  },
  "paper_search": {
    "daily_cron": "09:00",
    "sources": [
      {
        "name": "arXiv",
        "enabled": true,
        "categories": [
          "cs.NE",
          "cs.AI",
          "cs.MA",
          "cs.SI",
          "physics.soc-ph",
          "cs.NI",
          "cs.DC"
        ],
        "keywords": [
          "emergent intelligence",
          "complex networks",
          "small-world",
          "scale-free"
        ]
      },
      {
        "name": "IEEE Xplore",
        "enabled": true,
        "keywords": [
          "complex networks",
          "emergent intelligence",
          "topology optimization",
          "intelligent computing networks"
        ]
      },
      {
        "name": "ACM Digital Library",
        "enabled": true,
        "keywords": [
          "intelligent computing networks",
          "topology",
          "flexible computing",
          "network intelligence"
        ]
      },
      {
        "name": "Nature/Science",
        "enabled": true,
        "keywords": [
          "emergent intelligence",
          "complex systems",
          "network dynamics"
        ]
      },
      {
        "name": "CNKI (知网)",
        "enabled": true,
        "keywords": [
          "复杂网络涌现智能",
          "智能算力网络",
          "拓扑优化",
          "高效计算",
          "灵活计算"
        ]
      }
    ]
  },
  "knowledge_graph": {
    "storage": "neo4j",
    "node_types": [
      "paper",
      "author",
      "concept",
      "method",
      "dataset",
      "experiment",
      "insight",
      "patent"
    ],
    "edge_types": [
      "cites",
      "builds_on",
      "contradicts",
      "related_to",
      "inspired_by",
      "applies_to"
    ],
    "bidirectional_tags": true,
    "tag_system": {
      "direction": [
        "TCC",
        "iNEST"
      ],
      "category": [
        "paper",
        "concept",
        "method",
        "experiment"
      ],
      "status": [
        "new",
        "reviewed",
        "integrated",
        "obsolete"
      ],
      "priority": [
        "high",
        "medium",
        "low"
      ]
    }
  },
  "sync": {
    "gitee_repo": "iBrainNest/i-nest",
    "gitee_branch": "main",
    "obsidian_path": "D:/obsidian",
    "auto_pull_on_start": true,
    "auto_push_on_change": true,
    "sync_interval_minutes": 30
  },
  "dashboard": {
    "update_interval": "hourly",
    "metrics": [
      "papers_scraped",
      "papers_imported",
      "insights_generated",
      "patents_drafting",
      "papers_writing",
      "code_commits",
      "sync_status",
      "agent_utilization",
      "experiment_results"
    ]
  }
}